#!/usr/bin/env ruby
# frozen_string_literal: true

require "rufus-scheduler"
require_relative "../boot"
require "providers"

scheduler = Rufus::Scheduler.new

# Backfill all providers on startup (staggered to avoid thundering herd)
Providers.all.each_with_index do |provider, i|
  scheduler.in("#{i * 2}s") do
    system("bundle exec rake #{provider.key.downcase}:backfill")
  end
end

# Schedule each provider based on its publish window
Provider.all.each do |provider|
  next unless provider.publish_time && provider.publish_days

  hours = [provider.publish_time, provider.publish_time + 1, provider.publish_time + 2].map { |h| h % 24 }
  cron = "*/30 #{hours.join(",")} * * #{provider.publish_days}"

  scheduler.cron(cron, overlap: false) do
    system("bundle exec rake #{provider.key.downcase}:backfill")
  end
end

scheduler.join
